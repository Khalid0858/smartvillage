PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/smartvillage?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_string_at_least_32_characters

# Firebase Admin SDK (from Service Account JSON)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Weather API - get free key at openweathermap.org
WEATHER_API_KEY=your_openweathermap_api_key

# CORS - your frontend URL
CLIENT_URL=http://localhost:3000
